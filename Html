              marginBottom: 14,
            }}>
              <h2 style={{ margin: 0, fontSize: 16, color: "#ccc" }}>
                <span style={{ color: "#FFD700", fontWeight: 800, fontSize: 20 }}>{inputNum}</span>
                {" "}ke baad aane wale numbers:
              </h2>
              <select
                value={showTop}
                onChange={e => setShowTop(Number(e.target.value))}
                style={{
                  background: "rgba(255,255,255,0.1)",
                  border: "1px solid rgba(255,255,255,0.2)",
                  color: "#fff",
                  padding: "4px 8px",
                  borderRadius: 8,
                  fontSize: 13,
                  cursor: "pointer",
                }}
              >
                <option value={5}>Top 5</option>
                <option value={10}>Top 10</option>
                <option value={15}>Top 15</option>
                <option value={20}>Top 20</option>
              </select>
            </div>

            {predictions.map((p, i) => (
              <div key={p.num} style={{
                background: i === 0
                  ? "linear-gradient(135deg, rgba(255,215,0,0.15), rgba(255,165,0,0.08))"
                  : "rgba(255,255,255,0.05)",
                border: i === 0
                  ? "1px solid rgba(255,215,0,0.4)"
                  : "1px solid rgba(255,255,255,0.08)",
                borderRadius: 14,
                padding: "14px 16px",
                marginBottom: 10,
                position: "relative",
                overflow: "hidden",
              }}>
                {/* bar fill */}
                <div style={{
                  position: "absolute",
                  left: 0,
                  top: 0,
                  bottom: 0,
                  width: `${(p.count / maxCount) * 100}%`,
                  background: i === 0
                    ? "rgba(255,215,0,0.08)"
                    : "rgba(255,255,255,0.03)",
                  borderRadius: 14,
                  pointerEvents: "none",
                }} />

                <div style={{ display: "flex", alignItems: "center", gap: 12, position: "relative" }}>
                  {/* Rank badge */}
                  <div style={{
                    width: 32,
                    height: 32,
                    borderRadius: "50%",
                    background: MEDAL_COLORS[i] || "rgba(255,255,255,0.15)",
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "center",
                    fontWeight: 700,
                    fontSize: 13,
                    color: i < 3 ? "#000" : "#fff",
                    flexShrink: 0,
                  }}>
                    {i + 1}
                  </div>

                  {/* Number */}
                  <div style={{ fontSize: 26, fontWeight: 800, letterSpacing: 3, minWidth: 52 }}>
                    {p.num}
                  </div>

                  {/* Percent bar */}
                  <div style={{ flex: 1 }}>
                    <div style={{
                      background: "rgba(255,255,255,0.1)",
                      borderRadius: 4,
                      height: 8,
                      overflow: "hidden",
                    }}>
                      <div style={{
                        width: `${(p.count / maxCount) * 100}%`,
                        height: "100%",
                        background: MEDAL_COLORS[i] || "#4B9EF5",
                        borderRadius: 4,
                        transition: "width 0.4s ease",
                      }} />
                    </div>
                  </div>

                  {/* Stats */}
                  <div style={{ textAlign: "right", flexShrink: 0 }}>
                    <div style={{ fontSize: 18, fontWeight: 700, color: MEDAL_COLORS[i] || "#fff" }}>
                      {p.pct}%
                    </div>
                    <div style={{ fontSize: 11, color: "#888" }}>
                      {p.count}x
                    </div>
                  </div>
                </div>
              </div>
            ))}

            {/* Footer note */}
            <div style={{
              marginTop: 16,
              padding: "12px 16px",
              background: "rgba(255,255,255,0.04)",
              borderRadius: 12,
              fontSize: 12,
              color: "#888",
              textAlign: "center",
              lineHeight: 1.6,
            }}>
              📊 Yeh predictions historical data par based hain.<br/>
              Jitna zyada percentage, utna zyada aane ki history hai.
            </div>
          </div>
        )}

        {/* Empty state */}
        {!inputNum && (
          <div style={{
            textAlign: "center",
            padding: "40px 20px",
            color: "#555",
          }}>
            <div style={{ fontSize: 48, marginBottom: 12 }}>🔢</div>
            <p style={{ margin: 0, fontSize: 15 }}>
              Upar 2-digit number daalo<br/>aur dekhein agla number kya ho sakta hai
            </p>
          </div>
        )}

      </div>
    </div>
  );
}
