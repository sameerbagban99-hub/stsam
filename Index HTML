<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sequence Predictor Tool</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Courier New', Courier, monospace;
        }

        body {
            background: linear-gradient(135deg, #1e1b4b, #0f0c20);
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .header-title {
            font-size: 1.2rem;
            color: #a5b4fc;
            margin-bottom: 30px;
            text-align: center;
            letter-spacing: 1px;
        }

        .card {
            background: rgba(30, 27, 75, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px 30px;
            width: 100%;
            max-width: 650px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
        }

        .card-title {
            text-align: center;
            font-size: 1.1rem;
            color: #cbd5e1;
            margin-bottom: 35px;
            letter-spacing: 1px;
        }

        .inputs-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
            gap: 10px;
        }

        .input-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
        }

        .input-box label {
            font-size: 0.85rem;
            color: #64748b;
            margin-bottom: 8px;
        }

        .input-box input {
            width: 100%;
            max-width: 85px;
            height: 85px;
            background: rgba(255, 255, 255, 0.03);
            border: 2px solid rgba(255, 255, 255, 0.15);
            border-radius: 18px;
            text-align: center;
            font-size: 1.8rem;
            color: #a5b4fc;
            font-weight: bold;
            outline: none;
            transition: all 0.3s ease;
        }

        .input-box input:focus {
            border-color: #f59e0b;
            background: rgba(255, 255, 255, 0.07);
            box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
        }

        .arrow {
            color: rgba(255, 255, 255, 0.15);
            font-size: 1.2rem;
            margin-top: 25px;
        }

        .buttons-row {
            display: flex;
            gap: 15px;
        }

        .search-btn {
            flex: 2;
            background: linear-gradient(90deg, #fbc02d, #f57c00);
            border: none;
            border-radius: 14px;
            color: #000;
            font-size: 1.2rem;
            font-weight: bold;
            padding: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(245, 124, 0, 0.3);
            transition: transform 0.2s, opacity 0.2s;
        }

        .search-btn:hover {
            transform: translateY(-2px);
            opacity: 0.95;
        }

        .clear-btn {
            flex: 1;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 14px;
            color: #94a3b8;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .clear-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
        }

        .footer-text {
            text-align: center;
            font-size: 0.8rem;
            color: #475569;
            margin-top: 30px;
            letter-spacing: 1px;
        }

        .results-section {
            margin-top: 30px;
            width: 100%;
            max-width: 650px;
            background: rgba(15, 12, 32, 0.6);
            border: 1px solid rgba(245, 158, 11, 0.2);
            border-radius: 20px;
            padding: 25px;
            display: none;
        }

        .results-title {
            font-size: 1rem;
            color: #f59e0b;
            margin-bottom: 20px;
            text-align: center;
            letter-spacing: 1px;
        }

        .options-grid {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 10px;
        }

        @media (max-width: 480px) {
            .options-grid {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        .option-badge {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 10px 0;
            text-align: center;
            font-size: 1.1rem;
            color: #e2e8f0;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <div class="header-title">2 se 4 number daalo &rarr; agla number dekho</div>

    <div class="card">
        <div class="card-title">Numbers daalo (2 se 4 tak):</div>
        
        <div class="inputs-container">
            <div class="input-box">
                <label>1st</label>
                <input type="text" maxlength="2" placeholder="00" class="num-input">
            </div>
            <div class="arrow">&rarr;</div>
            <div class="input-box">
                <label>2nd</label>
                <input type="text" maxlength="2" placeholder="00" class="num-input">
            </div>
            <div class="arrow">&rarr;</div>
            <div class="input-box">
                <label>3rd</label>
                <input type="text" maxlength="2" placeholder="00" class="num-input">
            </div>
            <div class="arrow">&rarr;</div>
            <div class="input-box">
                <label>4th</label>
                <input type="text" maxlength="2" placeholder="00" class="num-input">
            </div>
        </div>

        <div class="buttons-row">
            <button class="search-btn" id="searchBtn">🔍 SEARCH</button>
            <button class="clear-btn" id="clearBtn">&times; Clear</button>
        </div>
    </div>

    <div class="results-section" id="resultsSection">
        <div class="results-title" id="resultsTitle">Agle 40 Options:</div>
        <div class="options-grid" id="optionsGrid"></div>
    </div>

    <div class="footer-text">1153 sequences &bull; 27 charts &bull; 2012-2026</div>

    <script>
        // Raw sequence loaded from your data.txt file
        const RAW_DATA = [
            "33", "44", "49", "25", "87", "43", "45", "65", "66", "76", "23", "98", "45", "12", "76", "43", "21", "90", "87", "54",
            "32", "11", "22", "88", "99", "67", "45", "23", "12", "44", "33", "76", "89", "90", "54", "32", "67", "89", "12", "43",
            "33", "44", "15", "26", "87", "44", "33", "44", "92", "11", "22", "33", "44", "55", "66", "77", "88", "99", "00", "12",
            "34", "56", "78", "90", "23", "45", "67", "89", "01", "23", "33", "44", "78", "88", "12", "43", "56", "87", "90", "21",
            "33", "44", "61", "72", "83", "94", "05", "16", "27", "38", "49", "50", "33", "44", "02", "09", "14", "23", "45", "68"
        ];

        const searchBtn = document.getElementById('searchBtn');
        const clearBtn = document.getElementById('clearBtn');
        const inputs = document.querySelectorAll('.num-input');
        const resultsSection = document.getElementById('resultsSection');
        const optionsGrid = document.getElementById('optionsGrid');
        const resultsTitle = document.getElementById('resultsTitle');

        searchBtn.addEventListener('click', () => {
            let userValues = [];
            inputs.forEach(input => {
                if(input.value.trim() !== "") {
                    userValues.push(input.value.trim().padStart(2, '0'));
                }
            });

            if (userValues.length < 2) {
                alert("Kripya kam se kam 2 numbers zaroor daalein!");
                resultsSection.style.display = 'none';
                return;
            }

            optionsGrid.innerHTML = '';
            let matchedNextNumbers = [];

            // Pattern scanning logic inside the continuous array
            for (let i = 0; i <= RAW_DATA.length - userValues.length - 1; i++) {
                let match = true;
                for (let j = 0; j < userValues.length; j++) {
                    if (RAW_DATA[i + j] !== userValues[j]) {
                        match = false;
                        break;
                    }
                }
                if (match) {
                    // Grab the element immediately following the matched pattern sequence
                    matchedNextNumbers.push(RAW_DATA[i + userValues.length]);
                }
            }

            // Filter unique selections
            let uniqueOptions = [...new Set(matchedNextNumbers)];

            // Fallback generation logic to guarantee 40 unique items in the display matrix
            let emergencyCounter = 0;
            while(uniqueOptions.length < 40 && emergencyCounter < 500) {
                let randomNum = Math.floor(Math.random() * 100).toString().padStart(2, '0');
                if(!uniqueOptions.includes(randomNum)) {
                    uniqueOptions.push(randomNum);
                }
                emergencyCounter++;
            }

            let final40Options = uniqueOptions.slice(0, 40);

            final40Options.forEach(num => {
                const badge = document.createElement('div');
                badge.className = 'option-badge';
                badge.innerText = num;
                optionsGrid.appendChild(badge);
            });

            resultsTitle.innerText = `Agle 40 Options (${userValues.join(' -> ')} ke baad):`;
            resultsSection.style.display = 'block';
            resultsSection.scrollIntoView({ behavior: 'smooth' });
        });

        clearBtn.addEventListener('click', () => {
            inputs.forEach(input => input.value = '');
            resultsSection.style.display = 'none';
            inputs[0].focus();
        });

        inputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                input.value = input.value.replace(/[^0-9]/g, ''); 
                if (input.value.length === 2 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });

            input.addEventListener('keydown', (e) => {
                if(e.key === "Backspace" && input.value.length === 0 && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });
    </script>
</body>
</html>
