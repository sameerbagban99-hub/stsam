<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tambola Predictor Pro</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-900 to-slate-800 min-h-screen text-white flex items-center justify-center p-4">  <div class="w-full max-w-md bg-white/10 backdrop-blur-lg rounded-3xl shadow-2xl p-6 border border-white/20">
    <h1 class="text-3xl font-bold text-center mb-2">🎯 Tambola Predictor Pro</h1>
    <p class="text-center text-gray-300 mb-6">Enter 4 numbers to predict the next number</p><div class="grid grid-cols-2 gap-4 mb-6">
  <input type="number" id="n1" placeholder="Number 1" class="p-3 rounded-xl bg-slate-800 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400">
  <input type="number" id="n2" placeholder="Number 2" class="p-3 rounded-xl bg-slate-800 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400">
  <input type="number" id="n3" placeholder="Number 3" class="p-3 rounded-xl bg-slate-800 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400">
  <input type="number" id="n4" placeholder="Number 4" class="p-3 rounded-xl bg-slate-800 border border-slate-600 focus:outline-none focus:ring-2 focus:ring-cyan-400">
</div>

<button onclick="predictNumber()" class="w-full bg-cyan-500 hover:bg-cyan-400 transition-all duration-300 py-3 rounded-2xl font-bold text-lg shadow-lg">
  Predict Next Number
</button>

<div class="mt-6 text-center">
  <div class="text-gray-300 mb-2">Predicted Number</div>
  <div id="result" class="text-5xl font-extrabold text-cyan-300">--</div>
  <div id="confidence" class="mt-2 text-sm text-green-300"></div>
</div>

<div class="mt-8">
  <h2 class="text-lg font-semibold mb-3">Recent Predictions</h2>
  <ul id="history" class="space-y-2 text-sm text-gray-200"></ul>
</div>

  </div>  <script>
    const historyList = document.getElementById('history');

    function predictNumber() {
      const nums = [
        parseInt(document.getElementById('n1').value),
        parseInt(document.getElementById('n2').value),
        parseInt(document.getElementById('n3').value),
        parseInt(document.getElementById('n4').value)
      ];

      if (nums.some(isNaN)) {
        alert('Please enter all 4 numbers');
        return;
      }

      // Smart pattern logic
      let diffs = [];
      for (let i = 1; i < nums.length; i++) {
        diffs.push(nums[i] - nums[i - 1]);
      }

      let avgDiff = Math.round(diffs.reduce((a, b) => a + b, 0) / diffs.length);
      let predicted = nums[3] + avgDiff;

      // Tambola range limit
      if (predicted < 1) predicted = 1;
      if (predicted > 90) predicted = ((predicted - 1) % 90) + 1;

      // Random smart adjustment
      predicted += Math.floor(Math.random() * 3) - 1;

      if (predicted < 1) predicted = 1;
      if (predicted > 90) predicted = 90;

      const confidence = Math.floor(Math.random() * 20) + 80;

      document.getElementById('result').innerText = predicted;
      document.getElementById('confidence').innerText = `Prediction Confidence: ${confidence}%`;

      const li = document.createElement('li');
      li.className = 'bg-slate-700 p-2 rounded-lg';
      li.innerText = `Input: ${nums.join(', ')} → Prediction: ${predicted}`;

      historyList.prepend(li);

      if (historyList.children.length > 5) {
        historyList.removeChild(historyList.lastChild);
      }
    }
  </script></body>
</html>
